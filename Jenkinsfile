pipeline {
  agent any

stages {

  stage('clone') {
    steps {
      echo 'Cloning code'
    }
  }

  stage('Build') {
    steps {
      echo 'Building clonned code'
    }
  }

  stage('Test') {
    steps {
      echo 'Running Tests'
    }
  }

  stage('Deploy') {
    steps {
      echo 'Deploying an Application'
    }
  }
}
}
